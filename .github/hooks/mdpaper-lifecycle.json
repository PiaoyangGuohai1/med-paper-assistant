{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "./scripts/hooks/copilot/session-init.sh",
        "timeout": 10
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "./scripts/hooks/copilot/prompt-analyzer.sh",
        "timeout": 5
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "./scripts/hooks/copilot/pre-tool-guard.sh",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "./scripts/hooks/copilot/post-tool-check.sh",
        "timeout": 15
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "./scripts/hooks/copilot/pre-compact-save.sh",
        "timeout": 10
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "./scripts/hooks/copilot/subagent-init.sh",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "./scripts/hooks/copilot/session-stop.sh",
        "timeout": 10
      }
    ]
  }
}
